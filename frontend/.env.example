# URL base da API Spring Boot (sem barra final)
# Desenvolvimento: http://localhost:8080
# Produção (Railway/Vercel — serviço do Next.js):
#   BACKEND_URL=https://seu-backend-spring.up.railway.app  (obrigatório: URL do Spring, não a do frontend)
#   NEXT_PUBLIC_API_URL=https://seu-backend-spring.up.railway.app
# Sem BACKEND_URL, o proxy /api/auth/* pode apontar para o host errado e /auth/me vira 404.
# Vercel → Settings → General → Root Directory = frontend (obrigatório para /api/auth/*).
# O backend deve listar a origem do Vercel em CORS_ALLOWED_ORIGINS (Railway).
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL do backend acessada pelo servidor Next.js (não exposta no bundle do cliente).
# Usada pelo Route Handler /api/auth/* para proxy de autenticação com cookie HttpOnly.
# Em produção, pode ser igual a NEXT_PUBLIC_API_URL ou uma URL interna (ex: http://backend:8080).
BACKEND_URL=http://localhost:8080
