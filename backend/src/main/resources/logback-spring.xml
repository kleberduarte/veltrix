<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ── Desenvolvimento: log legível no console ──────────────────────────── -->
  <springProfile name="!prod">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%X{traceId:-no-trace})] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="com.veltrix" level="DEBUG"/>
    <logger name="org.springframework.web" level="INFO"/>
  </springProfile>

  <!-- ── Produção: JSON estruturado para Railway/Datadog/Loki ─────────────── -->
  <springProfile name="prod">
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <!--
          JSON manual sem dependência de logstash-logback-encoder.
          Campos: timestamp, level, traceId, logger, message.
        -->
        <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%-5level","traceId":"%X{traceId:-}","logger":"%logger{36}","message":"%replace(%msg){'\"','\\\"'}"}%n</pattern>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="JSON_CONSOLE"/>
    </root>

    <logger name="com.veltrix" level="INFO"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>
  </springProfile>

</configuration>
