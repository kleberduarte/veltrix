# ─── Variáveis de ambiente obrigatórias em PRODUÇÃO ──────────────────────────
# Copie este arquivo para .env (nunca versione .env)

# ─── Banco de dados ───────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://seu-host:3306/veltrix?useSSL=true&requireSSL=true&serverTimezone=America/Sao_Paulo
DB_USER=veltrix_app
DB_PASSWORD=SENHA_FORTE_AQUI

# ─── JWT (OBRIGATÓRIO — mínimo 32 chars, use: openssl rand -base64 48) ────────
JWT_SECRET=GERE_COM_openssl_rand_base64_48
JWT_EXPIRATION=3600000

# ─── CORS (origens do frontend separadas por vírgula) ─────────────────────────
CORS_ALLOWED_ORIGINS=https://app.suaempresa.com.br

# ─── JPA (não alterar em produção) ───────────────────────────────────────────
JPA_DDL_AUTO=validate

# ─── Perfil Spring ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ─── Bootstrap: Adm Global (desabilite após o primeiro boot em produção) ──────
GLOBAL_ADMIN_BOOTSTRAP_ENABLED=true
GLOBAL_ADMIN_EMAIL=seu-email-admin@empresa.com.br
GLOBAL_ADMIN_PASSWORD=SENHA_FORTE_AQUI
GLOBAL_ADMIN_NAME=Administrador
GLOBAL_ADMIN_COMPANY=Sistema

# ─── Bootstrap: Admin Empresa (opcional) ─────────────────────────────────────
ADMIN_EMPRESA_BOOTSTRAP_ENABLED=false
