# ──────────────────────────────────────────────────────────────────────────────
# Variáveis para o serviço BACKEND no Railway
# Dashboard → projeto → serviço Java → Variables
#
# Guia completo: docs/deploy-producao.md
# ──────────────────────────────────────────────────────────────────────────────

# O Dockerfile define SPRING_PROFILES_ACTIVE=prod. Só defina aqui se precisar sobrescrever.

# ─── MySQL (mesmo projeto Railway) ────────────────────────────────────────────
# Preferência: botão "Reference" nas variáveis do plugin MySQL.
# Erro "Connection refused" / JDBC: host/porta/senha incorretos — use MYSQLHOST (rede interna).
# Docs: https://docs.railway.com/guides/mysql
#
# Evite RAILWAY_TCP_PROXY_* para o backend falar com o DB no mesmo projeto.

DB_URL=jdbc:mysql://${MYSQLHOST}:${MYSQLPORT}/${MYSQLDATABASE}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
DB_USER=root
# Railway expõe MYSQL_ROOT_PASSWORD para o root do plugin — referencie ou cole valor literal.
# NÃO use DB_PASSWORD=${MYSQLPASSWORD} (nome errado / placeholder aninhado).

# Alternativa com nome do serviço (ajuste "MySQL" ao nome no painel):
# DB_URL=jdbc:mysql://${{MySQL.MYSQLHOST}}:${{MySQL.MYSQLPORT}}/${{MySQL.MYSQLDATABASE}}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
# DB_USER=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ─── JPA / Flyway ─────────────────────────────────────────────────────────────
JPA_DDL_AUTO=validate

# Não force FLYWAY_OUT_OF_ORDER=false no Railway se a base tiver histórico fora de ordem;
# o projeto usa out-of-order conforme application.properties.

# ─── JWT (obrigatório em produção) ───────────────────────────────────────────
# Gere: openssl rand -base64 48
JWT_SECRET=TROQUE_openssl_rand_base64_48_min_32_CHARS
JWT_EXPIRATION=3600000

# ─── CORS — origem exata do frontend no Vercel (sem / no final). Várias: vírgula ─
CORS_ALLOWED_ORIGINS=https://seu-app.vercel.app

# ─── Bootstrap admin global (desligue após o primeiro uso em PRD) ────────────
GLOBAL_ADMIN_BOOTSTRAP_ENABLED=true
GLOBAL_ADMIN_EMAIL=adm.global@veltrix.local
GLOBAL_ADMIN_PASSWORD=TroqueEstaSenha

# ─── Flyway repair (só se migração falhar — ver README / deploy doc) ─────────
# mvn flyway:repair -Dflyway.url="jdbc:mysql://HOST:PORT/DB?..." -Dflyway.user=... -Dflyway.password=...
