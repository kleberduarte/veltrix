# ──────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente para configurar no Railway
# Dashboard → projeto → serviço do BACKEND → Variables
#
# Erro "Connection refused" / "Communications link failure":
# - Host/porta do MySQL incorretos, ou MySQL não está acessível ao container do app.
# - Use rede interna: MYSQLHOST, MYSQLPORT, MYSQLDATABASE (aba Variables do MySQL).
# - Evite RAILWAY_TCP_PROXY_* para o backend falar com o DB no mesmo projeto.
# Docs: https://docs.railway.com/guides/mysql
# ──────────────────────────────────────────────────────────────────────────────

# Recomendado: no serviço do backend, referencie as variáveis do plugin MySQL (botão "Reference").
# Senha: use MYSQL_ROOT_PASSWORD (Railway) — NÃO use DB_PASSWORD=${MYSQLPASSWORD} (nome errado / placeholder aninhado).
# Pode omitir DB_USER/DB_PASSWORD se MYSQL_ROOT_PASSWORD e MYSQLUSER estiverem no ambiente (ver application-prod).
DB_URL=jdbc:mysql://${MYSQLHOST}:${MYSQLPORT}/${MYSQLDATABASE}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
DB_USER=root
# Opcional se MYSQL_ROOT_PASSWORD já estiver injetado no serviço:
# (ou cole a senha em DB_PASSWORD em texto plano, sem ${...} aninhado)

# Alternativa referenciando o serviço pelo nome (ajuste "MySQL" ao nome no painel):
# DB_URL=jdbc:mysql://${{MySQL.MYSQLHOST}}:${{MySQL.MYSQLPORT}}/${{MySQL.MYSQLDATABASE}}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
# DB_USER=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# JPA — usar validate em produção (Flyway cuida das migrations)
JPA_DDL_AUTO=validate

# JWT — gere uma chave forte: openssl rand -base64 48
JWT_SECRET=TROQUE_OPENSSL_RAND_BASE64_48_MIN_32_CHARS
JWT_EXPIRATION=3600000

# CORS — URL do seu frontend no Vercel
CORS_ALLOWED_ORIGINS=https://veltrix-gold.vercel.app

# Admin global (primeiro acesso)
GLOBAL_ADMIN_BOOTSTRAP_ENABLED=true
GLOBAL_ADMIN_EMAIL=adm.global@veltrix.local
GLOBAL_ADMIN_PASSWORD=AdmGlobal2024!
