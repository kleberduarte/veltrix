# ──────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente para configurar no Railway
# Dashboard → seu projeto → backend service → Variables
# ──────────────────────────────────────────────────────────────────────────────

# Banco de dados (Railway gera automaticamente ao adicionar o MySQL plugin)
DB_URL=jdbc:mysql://${{MySQL.RAILWAY_TCP_PROXY_DOMAIN}}:${{MySQL.RAILWAY_TCP_PROXY_PORT}}/railway?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
DB_USER=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# JPA — usar validate em produção (Flyway cuida das migrations)
JPA_DDL_AUTO=validate

# JWT — gere uma chave forte: openssl rand -base64 48
JWT_SECRET=TROQUE_POR_UMA_CHAVE_FORTE_COM_32_CHARS_OU_MAIS
JWT_EXPIRATION=3600000

# CORS — URL do seu frontend no Vercel
CORS_ALLOWED_ORIGINS=https://veltrix.vercel.app

# Admin global (primeiro acesso)
GLOBAL_ADMIN_BOOTSTRAP_ENABLED=true
GLOBAL_ADMIN_EMAIL=adm@seudominio.com
GLOBAL_ADMIN_PASSWORD=TroqueEssaSenha2024!
